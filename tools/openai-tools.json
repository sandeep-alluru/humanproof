[
  {
    "type": "function",
    "function": {
      "name": "score_trajectory",
      "description": "Score a single input trajectory to determine if it was generated by a human or an AI agent. Returns human_score, ai_score, verdict, and motor feature flags.",
      "strict": true,
      "parameters": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "Optional session identifier for the trajectory."
          },
          "samples": {
            "type": "array",
            "description": "List of input samples, each with dx, dy (pixel deltas) and dt (milliseconds).",
            "items": {
              "type": "object",
              "properties": {
                "dx": { "type": "number", "description": "X-axis delta in pixels." },
                "dy": { "type": "number", "description": "Y-axis delta in pixels." },
                "dt": { "type": "number", "description": "Time delta in milliseconds (must be > 0)." },
                "timestamp": { "type": "number", "description": "Absolute timestamp in ms (optional)." }
              },
              "required": ["dx", "dy", "dt"],
              "additionalProperties": false
            }
          }
        },
        "required": ["samples"],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "batch_score_trajectories",
      "description": "Score multiple input trajectories at once. Returns a list of MotorScore results with human/AI verdicts.",
      "strict": true,
      "parameters": {
        "type": "object",
        "properties": {
          "trajectories": {
            "type": "array",
            "description": "List of trajectory dicts, each with an optional session_id and required samples array.",
            "items": {
              "type": "object",
              "properties": {
                "session_id": { "type": "string" },
                "samples": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "dx": { "type": "number" },
                      "dy": { "type": "number" },
                      "dt": { "type": "number" },
                      "timestamp": { "type": "number" }
                    },
                    "required": ["dx", "dy", "dt"],
                    "additionalProperties": false
                  }
                }
              },
              "required": ["samples"],
              "additionalProperties": false
            }
          }
        },
        "required": ["trajectories"],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "list_stored_scores",
      "description": "List all previously stored humanproof scores from the local SQLite store. Returns trajectory IDs, verdicts, and human/AI probabilities.",
      "strict": true,
      "parameters": {
        "type": "object",
        "properties": {},
